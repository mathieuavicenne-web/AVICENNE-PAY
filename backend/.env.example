# ---------------------------------------------------------
# FICHIER D'EXEMPLE DES VARIABLES D'ENVIRONNEMENT (BACKEND)
# Dupliquez ce fichier, renommez-le en ".env" et remplissez les valeurs.
# ---------------------------------------------------------

# Clé secrète pour signer les tokens JWT (Mettez une longue chaîne aléatoire)
SECRET_KEY="votre_cle_secrete_super_securisee_ici"

# Algorithme utilisé pour le JWT
ALGORITHM="HS256"

# Durée de validité du token d'accès en minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# URLs autorisées pour le CORS (séparées par des virgules)
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"